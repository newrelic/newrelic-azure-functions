# Shared configuration for VNet Flow Logs provisioning scripts.
# Source this file from within each script.

# Unique suffix — pin by exporting SUFFIX before running either script.
SUFFIX="preethi"

# Resource Group & Location
RG="rg-nrvnetflow-${SUFFIX}"
LOC="${LOC:-eastus}"

# VNet
VNET="vnet-nrvnetflow-${SUFFIX}"
VNET_CIDR="10.42.0.0/16"
SUBNET="default"
SUBNET_CIDR="10.42.0.0/24"

# Storage (shared between flow-log destination and cursor table)
STORAGE="stnrvnetflow${SUFFIX}"
TABLE="cursors"
FLOWLOG_CONTAINER="insights-logs-flowlogflowevent"

# Flow Log
FLOWLOG_NAME="fl-vnet-${SUFFIX}"

# Event Hub
EHNS="ehns-nrvnetflow-${SUFFIX}"
EH="eh-vnetflow"
EH_CG="nrvnetflowcg"

# Event Grid
EVG_SUB="evgsub-nrvnetflow-${SUFFIX}"

# Function App
FUNCAPP="func-nrvnetflow-${SUFFIX}"

# New Relic
NR_ENDPOINT="${NR_ENDPOINT:-https://log-api.newrelic.com/log/v1}"
